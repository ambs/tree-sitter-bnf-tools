{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "bnf",
  "rules": {
    "grammar": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "rule"
      }
    },
    "rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "nonTerminal"
        },
        {
          "type": "STRING",
          "value": "->"
        },
        {
          "type": "SYMBOL",
          "name": "ruleBody"
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "ruleBody": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "symbolSeq"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "|"
              },
              {
                "type": "SYMBOL",
                "name": "symbolSeq"
              }
            ]
          }
        }
      ]
    },
    "symbolSeq": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "symbol"
      }
    },
    "symbol": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "nonTerminal"
            },
            {
              "type": "SYMBOL",
              "name": "_terminal"
            },
            {
              "type": "SYMBOL",
              "name": "subSeq"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_kleeneOp"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "_kleeneOp": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "plus"
        },
        {
          "type": "SYMBOL",
          "name": "asterisk"
        }
      ]
    },
    "plus": {
      "type": "STRING",
      "value": "+"
    },
    "asterisk": {
      "type": "STRING",
      "value": "*"
    },
    "subSeq": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "ruleBody"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_terminal": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "pattern"
        },
        {
          "type": "SYMBOL",
          "name": "literal"
        }
      ]
    },
    "pattern": {
      "type": "PATTERN",
      "value": "\\/([^/]|\\[[^]]+\\]|\\\\\\/)+\\/"
    },
    "literal": {
      "type": "PATTERN",
      "value": "'([^']|\\\\')+'"
    },
    "nonTerminal": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}